<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Networking: push to laptop over local WiFi + Firebase fallback -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <!-- Health Connect: read step data synced from Huawei Health -->
    <uses-permission android:name="android.permission.health.READ_STEPS" />

    <!--
      Declare that we intend to interact with the Health Connect app. Required on
      Android 11+ (package visibility) so HealthConnectClient can resolve it, and
      so the "privacy policy / rationale" intent can be handled.
    -->
    <queries>
        <package android:name="com.google.android.apps.healthdata" />
        <intent>
            <action android:name="androidx.health.ACTION_SHOW_PERMISSIONS_RATIONALE" />
        </intent>
        <!-- Android 14+ Health Connect permission rationale action -->
        <intent>
            <action android:name="android.intent.action.VIEW_PERMISSION_USAGE" />
            <category android:name="android.intent.category.HEALTH_PERMISSIONS" />
        </intent>
    </queries>

    <application
        android:allowBackup="true"
        android:icon="@android:drawable/ic_dialog_info"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.TypedPondCompanion">

        <activity
            android:name=".MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>

            <!--
              Health Connect calls back into the app to show the permission
              rationale. Both actions are declared so the app works on
              pre-Android-14 (ACTION_SHOW_PERMISSIONS_RATIONALE) and
              Android 14+ (VIEW_PERMISSION_USAGE + HEALTH_PERMISSIONS) devices.
            -->
            <intent-filter>
                <action android:name="androidx.health.ACTION_SHOW_PERMISSIONS_RATIONALE" />
            </intent-filter>
        </activity>

        <!-- Alias for Android 14+ Health Connect rationale entry point. -->
        <activity-alias
            android:name="ViewPermissionUsageActivity"
            android:exported="true"
            android:targetActivity=".MainActivity"
            android:permission="android.permission.START_VIEW_PERMISSION_USAGE">
            <intent-filter>
                <action android:name="android.intent.action.VIEW_PERMISSION_USAGE" />
                <category android:name="android.intent.category.HEALTH_PERMISSIONS" />
            </intent-filter>
        </activity-alias>

    </application>

</manifest>
