<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/app_name"
            android:textSize="24sp"
            android:textStyle="bold"
            android:paddingBottom="16dp" />

        <TextView
            android:id="@+id/stepsText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="18sp"
            android:paddingBottom="4dp"
            android:text="@string/steps_unknown" />

        <TextView
            android:id="@+id/goalText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="18sp"
            android:paddingBottom="4dp"
            android:text="@string/goal_unknown" />

        <TextView
            android:id="@+id/lastSyncText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="14sp"
            android:paddingBottom="4dp"
            android:text="@string/last_sync_none" />

        <TextView
            android:id="@+id/signInStatusText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="14sp"
            android:paddingBottom="16dp"
            android:text="@string/not_signed_in" />

        <Button
            android:id="@+id/grantButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/grant_step_access" />

        <Button
            android:id="@+id/signInButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/firebase_sign_in" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="16dp"
            android:background="?android:attr/listDivider" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/laptop_ip_label"
            android:textSize="14sp"
            android:paddingBottom="4dp" />

        <EditText
            android:id="@+id/manualIpInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/laptop_ip_hint"
            android:inputType="text"
            android:autofillHints="" />

        <Button
            android:id="@+id/saveIpButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/save_ip" />

        <Button
            android:id="@+id/syncNowButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/sync_now" />

    </LinearLayout>

</ScrollView>
