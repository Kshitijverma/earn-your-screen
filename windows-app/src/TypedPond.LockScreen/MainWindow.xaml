<Window x:Class="TypedPond.LockScreen.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="TypedPond"
        WindowState="Maximized"
        WindowStyle="None"
        Topmost="True"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        AllowsTransparency="False"
        Background="#0B1026"
        FontFamily="Segoe UI"
        UseLayoutRounding="True">

    <Window.Resources>
        <!-- Calming but firm deep blue / purple gradient. -->
        <LinearGradientBrush x:Key="BackdropBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#0B1026" Offset="0.0" />
            <GradientStop Color="#1A1440" Offset="0.5" />
            <GradientStop Color="#2A1A4A" Offset="1.0" />
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="ProgressBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#4FD1C5" Offset="0.0" />
            <GradientStop Color="#63B3ED" Offset="1.0" />
        </LinearGradientBrush>
    </Window.Resources>

    <Grid Background="{StaticResource BackdropBrush}">

        <!-- Clock, top-right. -->
        <TextBlock x:Name="ClockText"
                   Text="--:--"
                   HorizontalAlignment="Right"
                   VerticalAlignment="Top"
                   Margin="0,36,48,0"
                   FontSize="30"
                   FontWeight="Light"
                   Foreground="#CBD5F5" />

        <!-- Centered content. -->
        <StackPanel HorizontalAlignment="Center"
                    VerticalAlignment="Center">

            <!-- Circular progress ring. -->
            <Grid Width="340" Height="340" HorizontalAlignment="Center">
                <!-- Track (faint full circle). -->
                <Ellipse Width="340" Height="340"
                         Stroke="#232A55"
                         StrokeThickness="20" />

                <!-- Progress arc (drawn in code-behind). -->
                <Path x:Name="ProgressArc"
                      Stroke="{StaticResource ProgressBrush}"
                      StrokeThickness="20"
                      StrokeStartLineCap="Round"
                      StrokeEndLineCap="Round" />

                <!-- Percentage in the center. -->
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock x:Name="PercentText"
                               Text="0%"
                               HorizontalAlignment="Center"
                               FontSize="64"
                               FontWeight="SemiBold"
                               Foreground="White" />
                    <TextBlock Text="of your goal"
                               HorizontalAlignment="Center"
                               FontSize="18"
                               Foreground="#8FA0D0" />
                </StackPanel>
            </Grid>

            <!-- Steps / goal. -->
            <TextBlock x:Name="StepsText"
                       Text="0 / 10,000 steps"
                       HorizontalAlignment="Center"
                       Margin="0,40,0,0"
                       FontSize="44"
                       FontWeight="SemiBold"
                       Foreground="White" />

            <!-- Motivational message. -->
            <TextBlock x:Name="MessageText"
                       Text="Time to get moving!"
                       HorizontalAlignment="Center"
                       Margin="0,18,0,0"
                       FontSize="26"
                       FontWeight="Light"
                       Foreground="#A9B7E8"
                       TextAlignment="Center"
                       TextWrapping="Wrap"
                       MaxWidth="760" />
        </StackPanel>

        <!-- Watermark, bottom center. -->
        <TextBlock Text="TypedPond"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Bottom"
                   Margin="0,0,0,28"
                   FontSize="15"
                   FontWeight="Light"
                   Foreground="#4A5486" />
    </Grid>
</Window>
